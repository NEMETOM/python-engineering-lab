{
  "id": null,
  "uid": "fixflux-tempo-traces",
  "title": "FIXFlux - Distributed Traces",
  "description": "Saved TraceQL queries for tracing single orders across the order-service to trade-store pipeline",
  "tags": ["fintech", "fix-protocol", "tempo", "traces", "opentelemetry"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 6,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "Order Lifecycle",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "type": "table",
      "title": "All Spans - Full Pipeline",
      "description": "Every span from every instrumented service. Each row is one span. Click a TraceID to open the full waterfall in Explore.\n\nTraceQL: {resource.service.name=~\"order-service|risk-service|matching-engine|trade-store\"}",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "options": { "sortBy": [] },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{resource.service.name=~\"order-service|risk-service|matching-engine|trade-store\"}",
          "tableType": "spans",
          "limit": 20,
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "table",
      "title": "Completed Trades (reached trade-store)",
      "description": "Spans from trade-store.persist only. If this span exists the order passed risk, was matched, and is in PostgreSQL.\n\nTraceQL: {name=\"trade-store.persist\"}",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 11 },
      "options": { "sortBy": [] },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{name=\"trade-store.persist\"}",
          "tableType": "spans",
          "limit": 20,
          "refId": "B"
        }
      ]
    },

    {
      "id": 4,
      "type": "table",
      "title": "Risk Evaluations (all orders)",
      "description": "All risk-service spans. Every order evaluation appears here regardless of outcome - approved and rejected share the same span name risk-service.validated_orders.\n\nTraceQL: {name=\"risk-service.validated_orders\"}",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 11 },
      "options": { "sortBy": [] },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{name=\"risk-service.validated_orders\"}",
          "tableType": "spans",
          "limit": 20,
          "refId": "C"
        }
      ]
    },

    {
      "id": 5,
      "type": "row",
      "title": "Latency & Performance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
    },

    {
      "id": 6,
      "type": "table",
      "title": "Slow Matching Engine Spans (> 50 ms)",
      "description": "Matching-engine spans over 50 ms. Adjust the threshold in the query editor.\n\nTraceQL: {name=\"matching-engine.process\" && duration > 50ms}",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 22 },
      "options": { "sortBy": [] },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{name=\"matching-engine.process\" && duration > 50ms}",
          "tableType": "spans",
          "limit": 20,
          "refId": "D"
        }
      ]
    },

    {
      "id": 7,
      "type": "row",
      "title": "Error Investigation",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },

    {
      "id": 8,
      "type": "table",
      "title": "Error Spans (any service)",
      "description": "Spans with status=error across all services. Should be empty in normal operation.\n\nTraceQL: {status=error}",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "options": { "sortBy": [] },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{status=error}",
          "tableType": "spans",
          "limit": 20,
          "refId": "E"
        }
      ]
    }

  ]
}
